generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  image          String?
  password       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  cvCredits      Int             @default(1)
  plan           String          @default("free")
  role           String          @default("user")
  provider       String?
  providerId     String?
  resetExpires   DateTime?
  resetToken     String?         @unique
  cvDocuments    CVDocument[]
  clientProjects ClientProject[]
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  project   String?
  budget    String?
  message   String
  read      Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CVDocument {
  id        String   @id @default(cuid())
  userId    String
  title     String
  data      String
  template  String   @default("modern")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id              String   @id @default(cuid())
  name            String
  description     String
  longDescription String?
  image           String   @default("/projects/placeholder.png")
  technologies    String
  status          String   @default("live")
  category        String   @default("webapp")
  progress        Int?
  launchDate      String?
  liveUrl         String?
  githubUrl       String?
  statsUsers      String?
  statsPerf       String?
  statsRoi        String?
  sortOrder       Int      @default(0)
  visible         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  demoVideo       String?
  featured        Boolean  @default(false)
}

model ServiceItem {
  id          String   @id @default(cuid())
  icon        String   @default("Rocket")
  title       String
  description String
  priceXOF    String
  priceEUR    String
  priceUSD    String
  features    String
  sortOrder   Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SkillGroup {
  id        String   @id @default(cuid())
  category  String
  skills    String
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model TestimonialItem {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String
  content   String
  rating    Int      @default(5)
  avatar    String?
  visible   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ExperienceItem {
  id           String   @id @default(cuid())
  period       String
  title        String
  company      String
  description  String
  achievements String
  current      Boolean  @default(false)
  sortOrder    Int      @default(0)
  visible      Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Int
  currency      String   @default("XOF")
  description   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cinetpayData  String?
  operator      String?
  paymentMethod String?
  plan          String?
  serviceType   String?
  transactionId String   @unique
  status        String   @default("PENDING")
}

model SiteSetting {
  id    String @id
  value String
}

model Upload {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
}

model PricingPlan {
  id              String   @id @default(cuid())
  serviceCategory String
  tierName        String
  tierLevel       Int      @default(0)
  description     String   @default("")
  priceXOF        String
  priceEUR        String
  priceUSD        String
  features        String
  deliveryTime    String   @default("")
  revisions       String   @default("")
  support         String   @default("")
  maintenanceXOF  String?
  maintenanceEUR  String?
  maintenanceUSD  String?
  popular         Boolean  @default(false)
  sortOrder       Int      @default(0)
  visible         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ClientProject {
  id          String             @id @default(cuid())
  userId      String
  name        String
  description String
  status      String             @default("discovery")
  priority    String             @default("normal")
  progress    Int                @default(0)
  budget      String?
  currency    String             @default("XOF")
  startDate   DateTime           @default(now())
  deadline    DateTime?
  completedAt DateTime?
  techStack   String?
  repoUrl     String?
  liveUrl     String?
  visible     Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones  ProjectMilestone[]
  updates     ProjectUpdate[]
}

model ProjectMilestone {
  id              String        @id @default(cuid())
  clientProjectId String
  title           String
  description     String?
  status          String        @default("pending")
  dueDate         DateTime?
  completedAt     DateTime?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clientProject   ClientProject @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)
}

model ProjectUpdate {
  id              String        @id @default(cuid())
  clientProjectId String
  authorRole      String        @default("admin")
  authorName      String
  title           String
  content         String
  type            String        @default("update")
  attachmentUrl   String?
  attachmentName  String?
  createdAt       DateTime      @default(now())
  clientProject   ClientProject @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)
}
